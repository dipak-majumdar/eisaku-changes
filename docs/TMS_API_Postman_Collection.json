		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "identifier",
									"value": "your_email_or_mobile",
									"type": "text"
								},
								{
									"key": "password",
									"value": "your_password",
									"type": "text"
								},
								{
									"key": "login_method",
									"value": "email",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/api/v1/accounts/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"accounts",
								"login"
							]
						},
						"description": "Login with email/mobile/username and password"
					},
					"response": []
				},
				{
					"name": "Get Current User",
					"request": {
